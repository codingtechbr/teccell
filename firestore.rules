rules_version = '2';

// ===========================================================
// Regras básicas do Firestore — TechStore PDV
//
// Estas regras exigem que o usuário esteja autenticado no Firebase
// (Firebase Authentication) para ler ou escrever qualquer dado.
//
// O sistema JÁ USA Firebase Authentication de verdade (login com
// e-mail e senha). Cada documento da coleção "usuarios" tem o ID igual
// ao UID do Firebase Auth do respectivo usuário — é assim que o app
// sabe o nível de acesso (Admin/Funcionário/Técnico) de quem logou.
// ===========================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Exige estar logado no Firebase Authentication para qualquer acesso
    function estaLogado() {
      return request.auth != null;
    }

    match /clientes/{docId} {
      allow read, write: if estaLogado();
    }
    match /produtos/{docId} {
      allow read, write: if estaLogado();
    }
    match /vendas/{docId} {
      allow read, write: if estaLogado();
    }
    match /ordens_servico/{docId} {
      allow read, write: if estaLogado();
    }
    match /movimentacoes_estoque/{docId} {
      allow read, write: if estaLogado();
    }
    match /caixa_sessoes/{docId} {
      allow read, write: if estaLogado();
    }
    match /caixa_movimentos/{docId} {
      allow read, write: if estaLogado();
    }
    match /config/{docId} {
      allow read, write: if estaLogado();
    }

    // Coleção de usuários do sistema (perfil/permissões, indexado pelo UID do
    // Firebase Auth). Qualquer pessoa logada pode ler/escrever aqui — inclusive
    // o próprio nível de acesso. Para uma loja pequena com poucos funcionários
    // de confiança isso já foi um upgrade de segurança grande (antes nem exigia
    // login). Se quiser travar mais (ex: só Admin altera nível de acesso de
    // outros), isso exige checar o papel de quem está fazendo a escrita — dá
    // pra evoluir depois com uma função tipo `souAdmin()` que lê o próprio
    // documento em /usuarios/$(request.auth.uid) e confere o campo "nivel".
    match /usuarios/{docId} {
      allow read, write: if estaLogado();
    }
  }
}

// ===========================================================
// MODO ABERTO (uso apenas em testes/desenvolvimento, NUNCA em produção)
// Descomente o bloco abaixo e comente o bloco acima se estiver apenas
// testando o sistema sem Firebase Authentication configurado ainda.
// ===========================================================
// service cloud.firestore {
//   match /databases/{database}/documents {
//     match /{document=**} {
//       allow read, write: if true;
//     }
//   }
// }
